# Alchemy API key used for RPC transports (required).
ALCHEMY_API_KEY=

# Reown (WalletConnect) project ID (required).
WALLETCONNECT_PROJECT_ID=

# DappLooker API key used for dashboard charts.
REACT_APP_DAPPLOOKER_API_KEY=

# Gnosis subgraph endpoint (HyperIndex) for registry data.
REACT_APP_SUBGRAPH_GNOSIS_ENDPOINT=https://indexer.hyperindex.xyz/[api-key]/v1/graphql

# Kleros Display Gnosis subgraph endpoint (The Graph) for policy/metadata.
REACT_APP_SUBGRAPH_KLEROS_DISPLAY_GNOSIS_ENDPOINT=https://gateway.thegraph.com/api/[api-key]/subgraphs/id/FxhLntVBELrZ4t1c2HNNvLWEYfBjpB8iKZiEymuFSPSr
